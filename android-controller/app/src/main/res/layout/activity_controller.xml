<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A">

    <!-- Full-screen button/trigger overlay -->
    <com.kinetix.controller.ControllerView
        android:id="@+id/controller_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Left analog stick -->
    <com.kinetix.controller.JoystickView
        android:id="@+id/left_joystick"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.45"
        app:layout_constraintDimensionRatio="H,1:1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="4%"
        android:layout_marginBottom="4%" />

    <!-- Right analog stick -->
    <com.kinetix.controller.JoystickView
        android:id="@+id/right_joystick"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.45"
        app:layout_constraintDimensionRatio="H,1:1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="4%"
        android:layout_marginBottom="4%" />

    <!-- Top status bar -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Connection indicator -->
        <TextView
            android:id="@+id/connection_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="● Connecting…"
            android:textColor="#F39C12"
            android:textSize="12sp" />

        <!-- Player indicator -->
        <TextView
            android:id="@+id/player_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:background="#2C2C54"
            android:paddingHorizontal="10dp"
            android:paddingVertical="2dp"
            android:fontFamily="sans-serif-medium"
            android:text="P1"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Battery indicator -->
        <TextView
            android:id="@+id/battery_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="🔋 100%"
            android:textColor="#2ECC71"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- Gyro toggle -->
        <ImageButton
            android:id="@+id/gyro_toggle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_compass"
            android:contentDescription="Toggle gyroscope"
            app:tint="#E94560"
            android:alpha="0.4" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
