<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/back_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Back"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Profile selector -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Controller Profile"
            android:textColor="#E94560"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/profile_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@android:drawable/btn_dropdown"
            android:popupBackground="#1A1A2E"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A2E"
            android:layout_marginBottom="24dp" />

        <!-- GYROSCOPE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gyroscope Aiming"
            android:textColor="#E94560"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Use Gyroscope → Right Stick"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/gyro_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#E94560"
                android:trackTint="#3A3A5E" />
        </LinearLayout>

        <TextView
            android:id="@+id/gyro_sensitivity_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sensitivity: 3.0"
            android:textColor="#7A7A9E"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/gyro_sensitivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="99"
            android:progress="29"
            android:progressTint="#E94560"
            android:thumbTint="#E94560"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A2E"
            android:layout_marginBottom="24dp" />

        <!-- VIBRATION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vibration Feedback"
            android:textColor="#E94560"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable Vibration"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/vibration_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#E94560"
                android:trackTint="#3A3A5E" />
        </LinearLayout>

        <TextView
            android:id="@+id/vibration_intensity_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Intensity: 100%"
            android:textColor="#7A7A9E"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/vibration_intensity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="100"
            android:progressTint="#E94560"
            android:thumbTint="#E94560"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A2E"
            android:layout_marginBottom="24dp" />

        <!-- PERFORMANCE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Performance"
            android:textColor="#E94560"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Update Rate"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/rate_spinner"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:background="@android:drawable/btn_dropdown"
                android:popupBackground="#1A1A2E" />
        </LinearLayout>

        <!-- Save button -->
        <Button
            android:id="@+id/save_btn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="#E94560"
            android:fontFamily="sans-serif-medium"
            android:text="SAVE PROFILE"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:letterSpacing="0.1"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
