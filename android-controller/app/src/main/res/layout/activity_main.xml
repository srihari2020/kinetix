<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient"
    android:clipChildren="false">

    <!-- Title -->
    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KINETIX"
        android:textColor="#FFFFFF"
        android:textSize="42sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:shadowColor="#E94560"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="25"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <TextView
        android:id="@+id/subtitle_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PRO CONTROLLER"
        android:textColor="#8888AA"
        android:textSize="14sp"
        android:letterSpacing="0.4"
        app:layout_constraintTop_toBottomOf="@id/title_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- 4 Circular Buttons Grid -->
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        app:layout_constraintTop_toBottomOf="@id/subtitle_text"
        app:layout_constraintBottom_toTopOf="@id/status_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:clipChildren="false">

        <!-- Gamepad -->
        <FrameLayout
            android:id="@+id/btn_gamepad"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_margin="16dp"
            android:clipChildren="false">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_neon_circle"
                android:backgroundTint="#DE2ECC71"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🎮\nGamepad"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Customize -->
        <FrameLayout
            android:id="@+id/btn_customize"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_margin="16dp"
            android:clipChildren="false">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_neon_circle"
                android:backgroundTint="#DEE94560"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✏️\nCustomize"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Connect -->
        <FrameLayout
            android:id="@+id/btn_connect"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_margin="16dp"
            android:clipChildren="false">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_neon_circle"
                android:backgroundTint="#DE3498DB"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🔌\nConnect"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Settings -->
        <FrameLayout
            android:id="@+id/btn_settings"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_margin="16dp"
            android:clipChildren="false">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_neon_circle"
                android:backgroundTint="#DE9B59B6"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⚙️\nSettings"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>
    </GridLayout>

    <!-- Status line -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap Gamepad to play • Customize to edit layout"
        android:textColor="#5A5A7E"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

    <!-- Connect Overlay (hidden by default) -->
    <include layout="@layout/view_connect_overlay"
        android:id="@+id/connect_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
