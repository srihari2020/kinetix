<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A">

    <!-- Full-screen button/trigger overlay -->
    <com.kinetix.controller.ControllerView
        android:id="@+id/controller_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Left analog stick -->
    <com.kinetix.controller.JoystickView
        android:id="@+id/left_joystick"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="16dp" />

    <!-- Right analog stick -->
    <com.kinetix.controller.JoystickView
        android:id="@+id/right_joystick"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp" />

    <!-- Edit mode overlay elements -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center"
        android:padding="12dp"
        android:orientation="horizontal"
        android:background="#80000000">

        <Button
            android:id="@+id/reset_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RESET"
            android:backgroundTint="#3A3A5E"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="16dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Drag buttons to reposition"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

        <Button
            android:id="@+id/save_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:backgroundTint="#E94560"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</FrameLayout>
